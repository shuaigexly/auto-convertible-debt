# ============================================================
# cb-auto-subscribe — Environment Variables Template
# Copy this file to .env and fill in the values before running
# ============================================================

# Database (required)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://cbuser:cbpass@db:5432/cbdb

# Encryption key for broker credentials (required)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate-with-fernet>

# Previous encryption key for key rotation (optional)
# Only set this during key rotation to allow decrypting old credentials
ENCRYPTION_KEY_OLD=

# ---- Notification Channels (all optional) ----

# Feishu (Lark) webhook URL
# Leave empty to disable Feishu notifications
FEISHU_WEBHOOK_URL=

# WeChat Work webhook URL
# Leave empty to disable WeChat notifications
WECHAT_WEBHOOK_URL=

# Email (SMTP) notifications
# Leave all empty to disable email notifications
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
# Comma-separated list of recipients
SMTP_TO=

# ---- Worker Settings ----

# Set to true to run subscription in dry-run mode (log only, no real orders)
DRY_RUN=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
