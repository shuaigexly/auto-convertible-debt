# Database
DATABASE_URL=postgresql+asyncpg://cbuser:cbpass@db:5432/cbdb

# Encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_ME

# Web UI auth token
API_SECRET_TOKEN=REPLACE_ME_32_CHARS

# Optional: second key for rotation (leave empty if not rotating)
ENCRYPTION_KEY_OLD=

# Timezone (do not change)
TZ=Asia/Shanghai
